{
  "name": "global-nav-blind-test",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev:1": "VITE_OPTION=1 vite",
    "dev:2": "VITE_OPTION=2 vite",
    "dev:3": "VITE_OPTION=3 vite",
    "build:1": "VITE_OPTION=1 vite build --outDir dist/option-1",
    "build:2": "VITE_OPTION=2 vite build --outDir dist/option-2",
    "build:3": "VITE_OPTION=3 vite build --outDir dist/option-3",
    "preview:1": "vite preview --outDir dist/option-1",
    "preview:2": "vite preview --outDir dist/option-2",
    "preview:3": "vite preview --outDir dist/option-3",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src Option_1 Option_2 Option_3 --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"Option_*/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.11.0",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^4.0.18"
  }
}
