# =============================================================================
# Global Nav Blind Test — Environment Variables
# =============================================================================
# Copy this file to .env.local for local overrides.
# .env.local is gitignored and will never be committed.
#
# IMPORTANT: Only variables prefixed with VITE_ are accessible in browser code.
# Variables without the VITE_ prefix are only available in vite.config.ts and
# other Node.js-side build scripts.
# =============================================================================


# -----------------------------------------------------------------------------
# Navigation Option (REQUIRED for manual vite invocations)
# -----------------------------------------------------------------------------
# Selects which navigation design to build or serve.
# Valid values: 1 | 2 | 3
#
# NOTE: This is set automatically by the dev:*, build:*, and preview:* npm
# scripts. You only need to set it manually if you are invoking vite directly
# (e.g., VITE_OPTION=2 npx vite).
# -----------------------------------------------------------------------------
VITE_OPTION=1


# -----------------------------------------------------------------------------
# Playwright / E2E Test Credentials (optional)
# -----------------------------------------------------------------------------
# If your E2E tests require authenticated sessions, provide credentials here.
# The QA skill (/qa-tester) will read these variables to create stub sessions.
# Leave blank if the application has no authentication wall.
# -----------------------------------------------------------------------------
# TEST_USER=
# TEST_PASSWORD=
# TEST_TOKEN=


# -----------------------------------------------------------------------------
# Feature Flags (optional, for future use)
# -----------------------------------------------------------------------------
# Boolean feature flags exposed to the browser. Set to "true" or "false".
# VITE_ prefix required for browser access.
# -----------------------------------------------------------------------------
# VITE_FEATURE_ANIMATIONS=true
